{
  "name": "teams-notifier",
  "version": "2.0.2",
  "description": "Send messages to a teams channel by means of an incoming webhook",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "lint": "eslint **.js",
    "update-readme": "node action-docs/update-readme.js && action-docs --update-readme",
    "build": "ncc build index.js -o dist",
    "prebuild": "pnpm test && pnpm lint && pnpm update-readme"
  },
  "author": "Richard Craddock",
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "axios": "^1.16.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.38.4",
    "action-docs": "^2.5.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.33.0",
  "volta": {
    "node": "24"
  }
}
